<Window x:Class="WindowLogin.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="500"
        Width="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- LADO ESQUERDO -->
        <Border Background="#1E293B">

            <StackPanel
                VerticalAlignment="Center"
                Margin="50">

                <TextBlock
                    Text="DiarTrip"
                    FontSize="42"
                    FontWeight="Bold"
                    Foreground="White"/>

                <TextBlock
                    Text="Painel Administrativo"
                    FontSize="22"
                    Margin="0,10,0,0"
                    Foreground="#CBD5E1"/>

                <TextBlock
                    Text="Gerencie relatórios, usuários e estatísticas da plataforma."
                    FontSize="16"
                    Margin="0,30,0,0"
                    TextWrapping="Wrap"
                    Foreground="#94A3B8"/>

            </StackPanel>

        </Border>

        <!-- LADO DIREITO -->
        <Grid Grid.Column="1">

            <Border
                Width="350"
                Padding="35"
                Background="#111827"
                CornerRadius="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <StackPanel>

                    <TextBlock
                        Text="Login"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="White"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        Text="Entre com sua conta Admin"
                        Foreground="#94A3B8"
                        Margin="0,10,0,30"
                        HorizontalAlignment="Center"/>

                    <!-- EMAIL -->
                    <TextBlock
                        Text="Email"
                        Foreground="White"
                        Margin="0,0,0,8"/>

                    <TextBox
                        x:Name="txtEmail"
                        Height="42"
                        Padding="10"
                        FontSize="15"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,0,20"/>

                    <!-- SENHA -->
                    <TextBlock
                        Text="Senha"
                        Foreground="White"
                        Margin="0,0,0,8"/>

                    <PasswordBox
                        x:Name="txtSenha"
                        Height="42"
                        Padding="10"
                        FontSize="15"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,0,30"/>

                    <!-- BOTÃO -->
                    <Button
                        x:Name="btnEntrar"
                        Content="Entrar"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnEntrar_Click" RenderTransformOrigin="0.5,0">

                        <Button.Style>
                            <Style TargetType="Button">

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                            <Border
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="12">

                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>

                                            </Border>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </Button.Style>

                    </Button>

                    <!-- ERRO -->
                    <TextBlock
                        x:Name="txtErro"
                        Foreground="#EF4444"
                        Margin="0,20,0,0"
                        TextAlignment="Center"
                        Visibility="Collapsed"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>