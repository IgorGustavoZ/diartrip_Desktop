<Window x:Class="WindowLobby.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard Admin"
        Height="720"
        Width="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid>

        <!-- SIDEBAR -->
        <Border Width="240"
                Background="#111827"
                HorizontalAlignment="Left">

            <StackPanel Margin="20" RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="0"/>
                        <RotateTransform/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </StackPanel.RenderTransform>

                <!-- LOGO -->
                <TextBlock Text="DiarTrip"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,40"/>
                <Button 
                        Content="📊 Dashboard" Height="30"/>

                <!-- MENU -->

                <Button
                        Content="👥 Usuários" Height="30"/>

                <Button
                        Content="✈ Viagens" Height="30"/>

                <Button 
                        Content="🤖 Relatórios IA" Height="30"/>

                <Button 
                        Content="📄 Exportar PDF" Height="30"/>
                <Button 
                        Content="⚙ Configurações" Height="30"/>

            </StackPanel>

        </Border>

        <!-- CONTEÚDO -->
        <Grid Margin="260,20,20,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Painel administrativo do sistema"
                               FontSize="16"
                               Foreground="#94A3B8"
                               Margin="0,8,0,0"/>

                </StackPanel>

                <Border Grid.Column="1"
                        Width="180"
                        Height="50"
                        CornerRadius="12"
                        Background="#1E293B"
                        HorizontalAlignment="Right">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="15,0">

                        <Ellipse Width="30"
                                 Height="30"
                                 Fill="#3B82F6"/>

                        <TextBlock Text="Admin"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   FontSize="15"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- CARDS -->
            <Grid Grid.Row="1"
                  Margin="0,35,0,35">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- CARD 1 -->
                <Border Grid.Column="0"
                        Margin="10,0,191,0"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25" Grid.ColumnSpan="2"
                        Width="300"
                        >

                    <StackPanel>

                        <TextBlock Text="Usuários"
                                   FontSize="18"
                                   Foreground="#CBD5E1"
                                   
                                   />

                        <TextBlock Text="0"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"
                                   Name="txtUsuarios"
                                   />

                    </StackPanel>

                </Border>

                <!-- CARD 2 -->
                <Border Grid.Column="1"
                        Margin="99,0,99,0"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25" Grid.ColumnSpan="2"
                        Width="300"
                        >

                    <StackPanel>

                        <TextBlock Text="Viagens"
                                   FontSize="18"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="0"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

                <!-- CARD 3 -->
                <Border Grid.Column="2"
                        Margin="189,0,10,0"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25" Grid.ColumnSpan="2"
                        Width="300"
                        >

                    <StackPanel>

                        <TextBlock Text="Mensagens IA"
                                   FontSize="18"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="0"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

                <!-- CARD 4 -->

            </Grid>

            <!-- TABELA -->
            <Border Grid.Row="2"
                    Background="#111827"
                    CornerRadius="20"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Usuários:"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,20"/>
                    <DataGrid
                        x:Name="gridUsuarios"
                        Height="107"
                        
                        IsReadOnly="True"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserResizeRows="False"
                        
                        AutoGenerateColumns="False"
                        Background="#1E293B"
                        Foreground="#fff"
                        BorderThickness="0"
                        HeadersVisibility="Column"
                        RowBackground="#1E293B"
                        AlternatingRowBackground="#273549"
                        GridLinesVisibility="None" Width="956">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Foreground" Value="#1E293B"/>

                                <Setter Property="FontSize" Value="14"/>

                                <Setter Property="Padding" Value="10,5,10,5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding id_usuario}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Nome"
                                                Binding="{Binding nome}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Email"
                                                Binding="{Binding email}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Data de criação"
                                                Binding="{Binding data_criacao}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <TextBlock Text="Viagens:"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

                    <DataGrid
                    x:Name="gridViagens"
                    Height="107"
    
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
    
                    AutoGenerateColumns="False"
                    Background="#1E293B"
                    Foreground="#fff"
                    BorderThickness="0"
                    HeadersVisibility="Column"
                    RowBackground="#1E293B"
                    AlternatingRowBackground="#273549"
                    GridLinesVisibility="None" Width="956">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Foreground" Value="#1E293B"/>

                                <Setter Property="FontSize" Value="14"/>

                                <Setter Property="Padding" Value="10,5,10,5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Id"
                            Binding="{Binding id_grupo}"
                            Width="*"/>

                            <DataGridTextColumn Header="Nome"
                            Binding="{Binding nome_grupo}"
                            Width="*"/>

                            <DataGridTextColumn Header="Destino"
                            Binding="{Binding destino_principal}"
                            Width="*"/>

                            <DataGridTextColumn Header="Criado por"
                            Binding="{Binding criado_por}"
                            Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>
                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>