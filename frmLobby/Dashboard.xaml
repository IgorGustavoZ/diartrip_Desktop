<Window x:Class="WindowLobby.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard Admin"
        Height="720"
        Width="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid>

        <!-- SIDEBAR -->
        <Border Width="240"
                Background="#111827"
                HorizontalAlignment="Left">

            <StackPanel Margin="20" RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="0"/>
                        <RotateTransform/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </StackPanel.RenderTransform>

                <!-- LOGO -->
                <TextBlock Text="DiarTrip"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,40"/>
                <Button 
                        Content="📊 Dashboard" Height="30"/>

                <!-- MENU -->

                <Button
                        Content="👥 Usuários" Height="30"/>

                <Button
                        Content="✈ Viagens" Height="30"/>

                <Button 
                        Content="🤖 Relatórios IA" Height="30"/>

                <Button 
                        Content="📄 Exportar PDF" Height="30"/>
                <Button 
                        Content="⚙ Configurações" Height="30"/>

            </StackPanel>

        </Border>

        <!-- CONTEÚDO -->
        <Grid Margin="260,20,20,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Painel administrativo do sistema"
                               FontSize="16"
                               Foreground="#94A3B8"
                               Margin="0,8,0,0"/>

                </StackPanel>

                <Border Grid.Column="1"
                        Width="180"
                        Height="50"
                        CornerRadius="12"
                        Background="#1E293B"
                        HorizontalAlignment="Right">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="15,0">

                        <Ellipse Width="30"
                                 Height="30"
                                 Fill="#3B82F6"/>

                        <TextBlock Text="Admin"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   FontSize="15"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- CARDS -->
            <Grid Grid.Row="1"
                  Margin="0,35,0,35">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- CARD 1 -->
                <Border Grid.Column="0"
                        Margin="0,0,15,0"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25">

                    <StackPanel>

                        <TextBlock Text="Usuários"
                                   FontSize="18"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="1.248"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

                <!-- CARD 2 -->
                <Border Grid.Column="1"
                        Margin="0,0,15,0"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25">

                    <StackPanel>

                        <TextBlock Text="Viagens"
                                   FontSize="18"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="532"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

                <!-- CARD 3 -->
                <Border Grid.Column="2"
                        Margin="0,0,15,0"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25">

                    <StackPanel>

                        <TextBlock Text="Mensagens IA"
                                   FontSize="18"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="12.5K"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

                <!-- CARD 4 -->
                <Border Grid.Column="3"
                        Background="#1E293B"
                        CornerRadius="20"
                        Padding="25">

                    <StackPanel>

                        <TextBlock Text="Destinos"
                                   FontSize="18"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="74"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- TABELA -->
            <Border Grid.Row="2"
                    Background="#111827"
                    CornerRadius="20"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Últimas viagens"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,20"/>

                    <DataGrid
                        x:Name="gridViagens"
                        Height="350"
                        AutoGenerateColumns="False"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        HeadersVisibility="Column"
                        RowBackground="#1E293B"
                        AlternatingRowBackground="#273549"
                        GridLinesVisibility="None">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Usuário"
                                                Binding="{Binding Usuario}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Destino"
                                                Binding="{Binding Destino}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Data"
                                                Binding="{Binding Data}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Orçamento"
                                                Binding="{Binding Orcamento}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>